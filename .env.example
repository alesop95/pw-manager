# Schema delle variabili d'ambiente dello stack (percorso Oracle Cloud).
# Copiare questo file in .env e sostituire i valori segnaposto con quelli reali.
# Il file .env non viene mai versionato (vedi .gitignore): poiche il repository
# e pubblico, qui restano anche gli identificatori di istanza (hostname e
# sottodominio), che individuano l'installazione e non devono finire nei file
# tracciati.

# Token dell'account DuckDNS, usato dal container duckdns per aggiornare
# l'IP pubblico della VM Oracle sul sottodominio dinamico.
DUCKDNS_TOKEN=your_duckdns_token_here

# Sottodominio DuckDNS, solo il prefisso senza ".duckdns.org".
# Consumato dal container duckdns come SUBDOMAINS.
DUCKDNS_SUBDOMAIN=vaultname

# Hostname pubblico completo (FQDN) dell'istanza.
# Consumato da Caddy nel blocco del sito (sintassi {$VW_HOSTNAME}) e da
# Vaultwarden per comporre l'URL del dominio (DOMAIN: "https://${VW_HOSTNAME}").
VW_HOSTNAME=vaultname.duckdns.org

# Hash Argon2 dell'ADMIN_TOKEN che protegge il pannello /admin di Vaultwarden.
# Generato prima dell'avvio con: docker run --rm -it vaultwarden/server /vaultwarden hash --preset owasp
ADMIN_TOKEN_HASH=your_argon2_hash_here

# Abilitazione delle registrazioni. Tenere a true solo il tempo di creare il
# primo account, poi riportare a false e riavviare lo stack.
SIGNUPS_ALLOWED=false
