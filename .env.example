# Schema delle variabili d'ambiente dello stack (percorso Oracle Cloud).
# Copiare questo file in .env e sostituire i valori segnaposto con quelli reali.
# Il file .env non viene mai versionato (vedi .gitignore): poiche il repository
# e pubblico, qui resta anche l'identificatore di istanza (hostname), che
# individua l'installazione e non deve finire nei file tracciati.

# Token dynDNS di deSEC (segreto), generato dal pannello desec.io.
# Usato dall'updater ddns per aggiornare il record DNS verso l'IP pubblico corrente.
DESEC_TOKEN=your_desec_token_here

# Hostname pubblico completo: il dominio dedyn.io registrato (es. nomescelto.dedyn.io).
# Consumato da Caddy nel blocco del sito (sintassi {$VW_HOSTNAME}), da Vaultwarden
# per comporre l'URL del dominio (DOMAIN: "https://${VW_HOSTNAME}") e dall'updater ddns.
VW_HOSTNAME=nomescelto.dedyn.io

# Hash Argon2 dell'ADMIN_TOKEN che protegge il pannello /admin di Vaultwarden.
# Generato prima dell'avvio con: docker run --rm -it vaultwarden/server /vaultwarden hash --preset owasp
ADMIN_TOKEN_HASH=your_argon2_hash_here

# Abilitazione delle registrazioni. Tenere a true solo il tempo di creare il
# primo account, poi riportare a false e riavviare lo stack.
SIGNUPS_ALLOWED=false
