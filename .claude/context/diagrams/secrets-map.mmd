%% Mappa dei segreti su tre custodi distinti e relative dipendenze.
%% Tutti i valori sono segnaposto: nessun segreto reale figura qui.
flowchart TB
    subgraph VW["Custode 1 - Vaultwarden"]
        pw["Password e dati di login"]
    end

    subgraph ENTE["Custode 2 - Ente Auth"]
        totp["Semi TOTP dei servizi"]
        vw2fa["Seme TOTP del secondo fattore di Vaultwarden"]
    end

    subgraph OFFLINE["Custode 3 - Custodia offline"]
        excel["Excel cifrato: master password, passphrase, recovery code"]
        bundle["secrets-bundle.7z: chiave SSH, DESEC_TOKEN, password admin"]
        agekey["Chiave privata age (decifratura backup)"]
    end

    pin["PIN estensione Chrome - locale per installazione"]
    cards["PIN bancari - mai in forma digitale"]

    vw2fa -.->|sblocca il secondo fattore di| pw
    excel -.->|recupero accesso a| pw
    agekey -.->|decifra i| backup["Backup cifrati su Object Storage"]
    pin -.->|sblocca autofill locale di| pw

    classDef warn fill:#fee,stroke:#a55;
    class cards warn;
